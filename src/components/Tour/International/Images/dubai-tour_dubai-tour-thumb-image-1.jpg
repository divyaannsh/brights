                    <div class="founder-img mb-3 mb-sm-4 mb-md-4 mb-lg-0 founder-image">
                        <img src="assets/images/shine_owner_2.jpg" class="img-fluid pt-0" height="100%" alt="">
                    </div>
                </div>
            </div>
        </div>
    </section>

