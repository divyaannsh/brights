<!-- Script -->
<script>
    $(".register__form").hide();
    $(".sign-in__button").click(function(e) {
        e.preventDefault();
        $(this).addClass("active");
        $(".register__button").removeClass("active");
        $(".login__form").show();
        $(".register__form").hide();
        $("#edit-email").focus(); //Should appear after $('.login__form').show(); because if it's before that, the register form doesn't exist in the DOM
    });
    $(".register__button").click(function(e) {
        e.preventDefault();
        $(this).addClass("active");
        $(".sign-in__button").removeClass("active");
        $(".register__form").show();
        $(".login__form").hide();
        $("#edit-firstname").focus(); //Should appear after $('.register__form').show(); because if it's before that, the register form doesn't exist in the DOM
    });
</script>

<!-- all booking popup js -->
<script>
    $('.header-booking-btn').click(function() {
        $('.header-booking-popup').addClass('booking-popup-open');
        $('.header-booking-popup').show();
        $('body').addClass('no-scroll');
    });
    $('.header-booking-cnt-inner-close, .booking-popup-open::after').click(function() {
        $('.header-booking-popup').removeClass('booking-popup-open');
        $('.header-booking-popup').hide();
        $('body').removeClass('no-scroll');
    });
</script>

<!-- header login popup js -->
<script>
    $(document).ready(function () {

        // forgot btn click popup
        $('#login_popup_forgot_btn').click(function() {
            $('#login_popup_forgot').removeClass('d-none');
            $('#login_popup_form').addClass('d-none');
        });
        // forgot return btn click popup
        $('#login_popup_return_btn').click(function() {
            $('#login_popup_form').removeClass('d-none');
            $('#login_popup_forgot').addClass('d-none');
        });

        // reset btn click popup
        $('#login_popup_reset_btn').click(function() {
            $('#login_popup_otp').removeClass('d-none');
            $('#login_popup_forgot').addClass('d-none');
        });
        // otp return btn click popup
        $('#login_popup_otp_return_btn').click(function() {
            $('#login_popup_form').removeClass('d-none');
            $('#login_popup_otp').addClass('d-none');
        });

        // submit otp btn click popup
        $('#login_popup_otp_submit_btn').click(function() {
            $('#login_popup_new_pswd').removeClass('d-none');
            $('#login_popup_otp').addClass('d-none');
        });

        // new password continue btn click popup
        $('#login_popup_new_pswd_continue_btn').click(function() {
            $('#login_popup_done').removeClass('d-none');
            $('#login_popup_new_pswd').addClass('d-none');
        });

        // done btn click popup
        $('#login_popup_done_btn').click(function() {
            $('#login_popup_form').removeClass('d-none');
            $('#login_popup_done').addClass('d-none');
        });

    });
</script>

<!-- header login otp popup js -->
<script>
  const inputs = document.querySelectorAll('.otp-input');

  inputs.forEach((input, index) => {
    input.addEventListener('input', (e) => {
      const val = input.value;

      // Allow only numbers
      if (!/^[0-9]$/.test(val)) {
        input.value = '';
        return;
      }

      // Enable and focus next input
      if (index < inputs.length - 1) {
        inputs[index + 1].disabled = false;
        inputs[index + 1].focus();
      }
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace') {
        if (input.value === '') {
          if (index > 0) {
            inputs[index - 1].focus();
            inputs[index - 1].value = '';
            for (let i = index; i < inputs.length; i++) {
              inputs[i].value = '';
              inputs[i].disabled = true;
            }
          }
        }
      }
    });

    // Prevent skipping ahead
    input.addEventListener('focus', () => {
      for (let i = 0; i < index; i++) {
        if (inputs[i].value === '') {
          inputs[i].focus();
          break;
        }
      }
    });
  });

  // Focus first input on load
  window.addEventListener('load', () => {
    inputs[0].focus();
  });
</script>

